# ── SAM AI Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — Flask session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-long-random-string

# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///./db.sqlite

# Session storage — "filesystem" for local dev, "redis" for production
SESSION_TYPE=filesystem

# Cookie security — must be "false" for HTTP localhost, "true" for HTTPS production
SESSION_COOKIE_SECURE=false

# Debug SQL logging
DEBUG=false

# CORS — comma-separated list of allowed frontend origins (beyond localhost)
# Example: ALLOWED_ORIGINS=https://yourapp.com,https://staging.yourapp.com
ALLOWED_ORIGINS=

# Email (optional) — enables PDF report delivery for breast cancer assessments
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
