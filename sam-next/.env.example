# ── SAM AI Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# API base URL — must use the same-origin proxy path so session cookies work
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api-backend

# Where the Next.js rewrite proxy forwards /api-backend/* requests
BACKEND_URL=http://localhost:5000

# Groq API key — powers the SAM AI chat widget (free tier at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
